# Ports
HTTP_PORT=8080
HTTPS_PORT=8443
PHPMYADMIN_PORT=8888
MAILPIT_PORT=8025

# Domains
LOCAL_DOMAIN=myproject.local
SITE_URL=https://myproject.local

# Versions
PHP_VERSION=8.4
NGINX_VERSION=1.26.1
MYSQL_VERSION=8.0.35
WP_VERSION=6.9.4

# Blog name
BLOG_NAME=BLOG NAME HERE

# Debug
WP_DEBUG=true

# WordPress admin
WP_ADMIN_USER=wp_admin_user
WP_ADMIN_PASSWORD=wp_admin_password
WP_ADMIN_EMAIL=your@email.here

# Themes
DOWNLOAD_CRETLACH_THEME=0
DELETE_DEFAULT_THEMES=0

# Plugins
INSTALL_FORMIDABLE=0
INSTALL_ICON_BLOCK=0
INSTALL_FILEBIRD=0

# Database
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=secret
